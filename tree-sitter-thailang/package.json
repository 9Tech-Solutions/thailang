{
  "name": "tree-sitter-thailang",
  "version": "0.1.0",
  "description": "Thailang tree-sitter grammar for syntax highlighting and parsing in editors, GitHub Linguist, and WASM playgrounds.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/9Tech-Solutions/thailang.git",
    "directory": "tree-sitter-thailang"
  },
  "license": "MIT",
  "author": {
    "name": "9Tech Solutions",
    "url": "https://github.com/9Tech-Solutions"
  },
  "main": "bindings/node",
  "types": "bindings/node",
  "files": [
    "grammar.js",
    "binding.gyp",
    "bindings/node/*",
    "queries/*",
    "src/**",
    "tree-sitter.json"
  ],
  "keywords": [
    "parsing",
    "incremental",
    "tree-sitter",
    "thailang",
    "thai"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp-build": "^4.8.0"
  },
  "peerDependencies": {
    "tree-sitter": "^0.24.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "devDependencies": {
    "prebuildify": "^6.0.0",
    "tree-sitter-cli": "^0.24.0"
  },
  "scripts": {
    "install": "node-gyp-build",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "node --test bindings/node/*_test.js",
    "build:wasm": "tree-sitter build --wasm && cp tree-sitter-thailang.wasm ../web/public/thailang.wasm"
  }
}
