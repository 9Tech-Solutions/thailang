{
  "name": "thailang",
  "displayName": "Thailang",
  "description": "Syntax highlighting and language support for Thailang, a Thai-first programming language that compiles to JavaScript and WebAssembly.",
  "version": "0.1.1",
  "publisher": "9Tech",
  "license": "MIT",
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1a1030",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "thai",
    "thailang",
    "ภาษาไทย",
    "programming language",
    "compiler",
    "wasm"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/9Tech-Solutions/thailang.git",
    "directory": "vscode-ext"
  },
  "bugs": {
    "url": "https://github.com/9Tech-Solutions/thailang/issues"
  },
  "homepage": "https://github.com/9Tech-Solutions/thailang#readme",
  "qna": "https://github.com/9Tech-Solutions/thailang/discussions",
  "contributes": {
    "languages": [
      {
        "id": "thailang",
        "aliases": [
          "Thailang",
          "ภาษาไทย"
        ],
        "extensions": [
          ".th"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "thailang",
        "scopeName": "source.thailang",
        "path": "./syntaxes/thailang.tmLanguage.json"
      }
    ]
  },
  "scripts": {
    "package": "vsce package --out thailang-${npm_package_version}.vsix",
    "publish": "vsce publish",
    "publish:ovsx": "ovsx publish thailang-${npm_package_version}.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.6.0"
  }
}
