{
  "name": "playground-wasm",
  "version": "0.1.0",
  "private": true,
  "description": "Thailang compiler as a WASM module — wraps wasm-pack output",
  "type": "module",
  "main": "./pkg/thailang_wasm.js",
  "types": "./pkg/thailang_wasm.d.ts",
  "files": ["pkg/"],
  "scripts": {
    "build": "wasm-pack build ../compiler/crates/thailang-wasm --target nodejs --out-dir ../../../playground-wasm/pkg --release",
    "build:web": "wasm-pack build ../compiler/crates/thailang-wasm --target web --out-dir ../../../playground-wasm/pkg --release"
  },
  "license": "MIT"
}
