{
  "name": "thailang-lacquer",
  "type": "dark",
  "colors": {
    "editor.background": "#00000000",
    "editor.foreground": "#f5ecdb"
  },
  "tokenColors": [
    {
      "scope": ["comment", "comment.line", "comment.block"],
      "settings": {
        "foreground": "#857796",
        "fontStyle": "italic"
      }
    },
    {
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#9dd6a3"
      }
    },
    {
      "scope": ["constant.character.escape"],
      "settings": {
        "foreground": "#f0a665"
      }
    },
    {
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#f0b974"
      }
    },
    {
      "scope": ["constant.language.boolean", "constant.language.null"],
      "settings": {
        "foreground": "#c99adf"
      }
    },
    {
      "scope": ["storage.type"],
      "settings": {
        "foreground": "#8fc4cc"
      }
    },
    {
      "scope": ["keyword.declaration"],
      "settings": {
        "foreground": "#c99adf",
        "fontStyle": ""
      }
    },
    {
      "scope": ["keyword.control"],
      "settings": {
        "foreground": "#eec98c"
      }
    },
    {
      "scope": ["keyword.other"],
      "settings": {
        "foreground": "#c99adf"
      }
    },
    {
      "scope": ["keyword.operator.logical"],
      "settings": {
        "foreground": "#eec98c"
      }
    },
    {
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#c5b7a7"
      }
    },
    {
      "scope": ["support.function.builtin"],
      "settings": {
        "foreground": "#f5d59b"
      }
    },
    {
      "scope": ["entity.name.function"],
      "settings": {
        "foreground": "#f5d59b"
      }
    },
    {
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#f5ecdb"
      }
    }
  ]
}
