// narrow.th, ทดสอบ type narrowing ด้วย `เป็น`
ฟังก์ชัน บรรยาย(ค่า: ตัวเลข | ข้อความ | ว่าง) {
    ถ้า (ค่า เป็น ข้อความ) {
        พิมพ์("ข้อความ: " + ค่า);
    } ไม่ก็ (ค่า เป็น ตัวเลข) {
        พิมพ์("ตัวเลข: " + ค่า);
    } ไม่งั้น {
        พิมพ์("ว่าง");
    }
}

บรรยาย("สวัสดี");
บรรยาย(42);
บรรยาย(ว่าง);
